# ==========================================
# Backend Environment Variables Template
# ==========================================
# Instructions: 
# Copy this file and rename it to exactly `.env` (with no extension).
# Replace the placeholder values with your real secret keys.
# Never commit your real `.env` file to Git!

# Brevo API Key for Email OTP Verification
# Get this from your Brevo Dashboard (SMTP & API -> API Keys)
BREVO_API_KEY=your_brevo_api_key_here
